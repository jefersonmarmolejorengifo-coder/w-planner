# =============================================================================
# Productivity-Plus (w-planner) — variables de entorno
# Copia este archivo a .env.local (frontend Vite) y/o configura estas variables
# en Vercel (funciones serverless). NO pongas valores reales en este archivo.
# =============================================================================

# ─── Supabase (frontend, expuestas al navegador con prefijo VITE_) ───────────
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ─── Supabase (backend / funciones Vercel) ──────────────────────────────────
# SUPABASE_URL/ANON_KEY pueden omitirse si ya defines las VITE_* (hay fallback).
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-publica
# Service role: SECRETO. Solo backend. Bypassa RLS (webhooks, cron, persistencia).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# Alias histórico aceptado si no defines SUPABASE_SERVICE_ROLE_KEY:
# SUPABASE_SERVICE_KEY=tu-service-role-key

# ─── IA: Anthropic (chat, reportes semanal/mensual, evolutivo) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── IA: Google Gemini (reporte Scrum) ──────────────────────────────────────
GEMINI_API_KEY=tu-gemini-api-key
# Alias aceptado: GOOGLE_API_KEY=tu-gemini-api-key
# Modelo opcional (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Mercado Pago (suscripciones premium) ───────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
# Secreto del webhook (dashboard de MP). Si se define, /api/mp-webhook EXIGE
# firma x-signature válida (recomendado en producción — H-001).
MP_WEBHOOK_SECRET=tu-mp-webhook-secret

# ─── Email transaccional: Resend (invitaciones y reportes) ───────────────────
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=Productivity-Plus <no-reply@tu-dominio.com>

# ─── Cron / jobs internos ────────────────────────────────────────────────────
# Secreto compartido que protege /api/cron y las llamadas internas (X-Cron-Secret).
CRON_SECRET=una-cadena-larga-aleatoria

# ─── App / CORS ──────────────────────────────────────────────────────────────
# URL base de la app (para links de invitación y back_url de pagos).
APP_BASE_URL=https://tu-dominio.vercel.app
# Orígenes extra permitidos para CORS, separados por coma (opcional).
# ALLOWED_ORIGINS=https://otro-dominio.com,https://staging.tu-dominio.com
# VERCEL_URL la inyecta Vercel automáticamente; no la definas manualmente.

# ─── Hub financiero (Soft a Tu Medida) — cable saliente Hub→w-planner ────────
# Receptor del evento `suscripcion.cobrada` emitido por el Hub cuando Wompi
# confirma el cobro de un ciclo recurrente. Protocolo X-Hub-Version: 1.
#
# HUB_WEBHOOK_SECRET: secreto HMAC-SHA256 compartido con el Hub. Es el mismo
#   valor que el campo `webhook_secret` del registro de w-planner en el Hub.
#   NUNCA lo pongas en el código ni en este archivo. Confíguralo en Vercel.
#   El receptor lo lee para verificar X-Signature; sin él → fail-closed (503).
HUB_WEBHOOK_SECRET=tu-hub-webhook-secret-compartido
#
# HUB_WEBHOOK_URL: URL del endpoint del Hub donde w-planner NOTIFICA sus pagos
#   de MP (dirección opuesta: w-planner→Hub). Usada por _hub-client.js.
#   Valor de producción: https://panel.softatumedida.com/api/webhook-app
HUB_WEBHOOK_URL=https://panel.softatumedida.com/api/webhook-app
#
# HUB_APP_SLUG: identificador de w-planner en el Hub. Incluido en el mensaje
#   firmado (${slug}.${timestamp}.${body}) para prevenir reatribución de
#   webhooks entre apps.
HUB_APP_SLUG=w-planner
#
# ─── Wompi (cobro vía Hub) — flags de frontend ───────────────────────────────
# VITE_WOMPI_CHECKOUT_ENABLED: si ="true", el frontend muestra el flujo de pago
#   Wompi (checkout del Hub) en lugar del flujo MP. Por defecto OFF para
#   mantener la experiencia MP mientras se migra gradualmente.
VITE_WOMPI_CHECKOUT_ENABLED=false
#
# VITE_HUB_CHECKOUT_BASE: URL base del panel Hub donde el usuario completa el
#   checkout de Wompi. El frontend construye el link de pago como:
#   ${VITE_HUB_CHECKOUT_BASE}/checkout?app=w-planner&plan=<tier>
VITE_HUB_CHECKOUT_BASE=https://panel.softatumedida.com

# ─── Flags de desarrollo ─────────────────────────────────────────────────────
# Si ="true", permite usar IA aunque la RPC de gating no exista (solo dev — H-006).
# Déjalo SIN definir en producción para mantener el fail-closed.
# ALLOW_IA_WITHOUT_RPC=true
