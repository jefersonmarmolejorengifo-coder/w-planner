{
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/send-report.js": {
      "maxDuration": 60
    },
    "api/cron.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/", "destination": "/app/index.html" },
    { "source": "/app/:path*", "destination": "/app/index.html" }
  ],
  "redirects": [
    { "source": "/", "has": [{ "type": "query", "key": "join" }], "destination": "/app" },
    { "source": "/", "has": [{ "type": "query", "key": "ref" }], "destination": "/app" },
    { "source": "/", "has": [{ "type": "query", "key": "billing" }], "destination": "/app" },
    { "source": "/", "has": [{ "type": "query", "key": "code" }], "destination": "/app" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
