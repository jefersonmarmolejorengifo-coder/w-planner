---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Layout base del sitio de marketing. Centraliza <head>, SEO, nav y footer.
const {
  title,
  description,
  path = '/',
  image = '/og-image.png',
  jsonld,
} = Astro.props;

const site = 'https://productivityplus.softatumedida.com';
const canonical = new URL(path, site).href;
const ogImage = new URL(image, site).href;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#0d0d1a" />
    <meta name="google-site-verification" content="1sGCoz1_WYasvozZgYI4iQliJp6FVoIOUNyCy3Rqdec" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Productivity-Plus" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_LA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
